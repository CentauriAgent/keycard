# ─── Apple Wallet (production only) ───────────────────────────
# Requires Apple Developer enrollment ($99/yr)
# Without these, /api/wallet/apple returns a JSON mock response
APPLE_CERT=              # base64-encoded .p12 signing certificate
APPLE_CERT_PASS=         # .p12 certificate password
APPLE_TEAM_ID=           # Apple Developer Team ID (e.g., XXXXXXXXXX)
APPLE_PASS_TYPE_ID=      # Pass type identifier (e.g., pass.card.key.contact)
APPLE_WWDR_CERT=         # base64-encoded Apple WWDR intermediate cert (optional)

# ─── Google Wallet (production only) ─────────────────────────
# Requires Google Pay & Wallet Console access
# Without these, /api/wallet/google returns an unsigned JWT mock
GOOGLE_SERVICE_ACCOUNT=  # base64-encoded Google service account JSON
GOOGLE_ISSUER_ID=        # Google Wallet issuer ID from Pay & Wallet Console

# ─── App config ──────────────────────────────────────────────
VITE_APP_URL=https://key.card
